# =============================================
# PRODUCTION PROFILE (Neon PostgreSQL)
# Copy this file to application-prod.properties
# and fill in your real values
# OR set as environment variables on Render
# =============================================

# Neon Database
spring.datasource.url=${SPRING_DATASOURCE_URL}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD}
spring.datasource.driver-class-name=org.postgresql.Driver

# Connection pool — fixes Neon timeout
spring.datasource.hikari.max-lifetime=180000
spring.datasource.hikari.keepalive-time=60000
spring.datasource.hikari.idle-timeout=120000
spring.datasource.hikari.minimum-idle=1
spring.datasource.hikari.maximum-pool-size=5
spring.datasource.hikari.connection-test-query=SELECT 1

# JPA
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.jdbc.lob.non_contextual_creation=true
spring.jpa.open-in-view=false

# H2 disabled in production
spring.h2.console.enabled=false

# CORS — your Vercel frontend URL
app.cors.allowed-origins=${FRONTEND_URL:http://localhost:5173}

# JWT
app.jwt.secret=${JWT_SECRET}
app.jwt.expiration=86400000

# Seed data — false after first run
app.seed-data=${SEED_DATA:false}

# SendGrid Email
app.sendgrid.api-key=${SENDGRID_API_KEY:}
app.sendgrid.from-email=${SENDGRID_FROM_EMAIL:noreply@clinicare.com}
